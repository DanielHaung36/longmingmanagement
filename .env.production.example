# 生产环境配置示例
# 复制此文件为 .env.production 并修改相应值

# 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION
POSTGRES_DB=projectmanagement

# Neo4j配置
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION

# Redis配置
REDIS_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION

# JWT配置 (必须更换为强密码)
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_KEY
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_STRONG_SECRET_KEY

# 应用配置
NODE_ENV=production
PORT=8081
FRONTEND_URL=https://yourdomain.com

# 邮件配置 (生产环境SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@longi.com
SMTP_FROM_NAME=Longi项目管理系统
