# ========================================
# 基础配置
# ========================================

# 环境模式：development | production
NODE_ENV=production

# 服务器端口
PORT=8081

# 前端地址（用于CORS配置）
FRONTEND_URL=http://localhost:3000

# ========================================
# 开发模式配置
# ========================================

# 自动登录（开发模式）- 跳过认证，自动使用DevAdmin用户
DEV_AUTO_LOGIN=true

# ========================================
# 日志配置
# ========================================

# 日志级别：DEBUG | INFO | WARN | ERROR
# DEBUG: 显示所有日志，包含代码位置（文件名:行号）
# INFO:  显示一般信息、警告和错误
# WARN:  仅显示警告和错误
# ERROR: 仅显示错误
LOG_LEVEL=DEBUG

# ========================================
# 数据库配置
# ========================================

# PostgreSQL主数据库
DATABASE_URL="postgresql://username:password@localhost:5432/longi_db"

# Neo4j知识图谱（可选）
NEO4J_URI="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="password"

# ========================================
# Redis缓存配置（暂未启用）
# ========================================

# 是否启用Redis缓存
REDIS_ENABLED=false

# Redis服务器地址
REDIS_HOST=localhost
REDIS_PORT=6379

# Redis密码（可选）
# REDIS_PASSWORD=your_password

# Redis数据库编号（0-15）
REDIS_DB=0

# Redis key前缀（用于区分不同环境）
REDIS_KEY_PREFIX=longi_pm:dev:

# ========================================
# 文件存储配置
# ========================================

# 本地项目文件夹根目录
LOCAL_PROJECT_ROOT="C:/Longi/ProjectData/Projects"

# OneDrive项目文件夹根目录
ONEDRIVE_PROJECT_ROOT="C:/Users/YourName/OneDrive/Longi/Projects"

# Excel文件路径
EXCEL_LOCAL_PATH="C:/Longi/ProjectData/项目数据库.xlsx"
EXCEL_ONEDRIVE_PATH="C:/Users/YourName/OneDrive/Longi/项目数据库.xlsx"

# 临时上传文件夹
TEMP_UPLOAD_DIR="./temp-uploads"

# ========================================
# JWT认证配置
# ========================================

# JWT密钥（生产环境请使用强密码）
JWT_SECRET="your-secret-key-change-in-production"

# JWT过期时间
JWT_EXPIRES_IN="7d"

# ========================================
# Temporal配置（可选）
# ========================================

# Temporal服务器地址
TEMPORAL_ADDRESS=localhost:7233

# Temporal命名空间
TEMPORAL_NAMESPACE=default

# 是否启动Worker
START_WORKER=true

# ========================================
# Azure AD / Microsoft Graph API 配置
# 用于 OneDrive 云端操作（防止删除后被恢复）
# ========================================

# Azure AD 租户 ID
AZURE_TENANT_ID=""

# Azure AD 应用程序（客户端）ID
AZURE_CLIENT_ID=""

# Azure AD 客户端密钥
AZURE_CLIENT_SECRET=""

# OneDrive 用户 ID 或 UPN（如果使用委托权限访问特定用户的 OneDrive）
# 例如：user@company.onmicrosoft.com 或用户的 Object ID
ONEDRIVE_USER_ID=""

# OneDrive 基础路径（相对于 OneDrive 根目录）
ONEDRIVE_BASE_PATH="03 Project Management"

# ========================================
# 其他配置
# ========================================

# API文档路径（Swagger UI）
API_DOCS_PATH=/api-docs

# 允许的文件上传大小（MB）
MAX_FILE_SIZE=100