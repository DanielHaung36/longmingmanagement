{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build && concurrently \"npx tsc -w\" \"nodemon --exec ts-node -r tsconfig-paths/register src/index.ts\"",
    "build": "npx prisma generate && rimraf dist && npx tsc",
    "start": "npm run build && node dist/index.js",
    "start:prod": "dotenv -e .env.production -- cross-env NODE_ENV=production npm run start",
    "reset:complete": "tsx src/scripts/completeReset.ts",
    "reset:complete:prod": "tsx src/scripts/completeReset.ts --production",
    "reset:complete:skip": "tsx src/scripts/completeReset.ts --skip-folders",
    "diagnose:excel": "tsx src/scripts/diagnoseExcel.ts",
    "create-dev-user": "tsx src/scripts/createDevUser.ts",
    "reset-admin-user": "tsx src/scripts/resetAdminPassword.ts",
    "seed:permissions": "tsx src/scripts/seedPermissions.ts",
    "seed:mine-zones": "tsx src/scripts/seedMineZones.ts"
  },
  "keywords": [],
  "author": "",
