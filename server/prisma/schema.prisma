model workflow_delegations {
  id                                           Int            @id @default(autoincrement())
  taskId                                       Int
  fromUserId                                   Int
  toUserId                                     Int
  reason                                       String?
  startTime                                    DateTime       @default(now())
  endTime                                      DateTime?
  isActive                                     Boolean        @default(true)
  users_workflow_delegations_fromUserIdTousers users          @relation("workflow_delegations_fromUserIdTousers", fields: [fromUserId], references: [id])
  workflow_tasks                               workflow_tasks @relation(fields: [taskId], references: [id])
  users_workflow_delegations_toUserIdTousers   users          @relation("workflow_delegations_toUserIdTousers", fields: [toUserId], references: [id])
}

model workflow_instances {
  id                 Int                    @id @default(autoincrement())
  templateId         Int
  templateVersion    Int
  businessType       String
  businessId         Int
  projectId          Int?
  title              String
  urgency            Priority               @default(MEDIUM)
  status             WorkflowInstanceStatus @default(RUNNING)
  currentNodes       String[]
  completedNodes     String[]
  startUserId        Int
  startTime          DateTime               @default(now())
  endTime            DateTime?
  deadline           DateTime?
  variables          Json?
  snapshot           Json
  projects           projects?              @relation(fields: [projectId], references: [id])
  users              users                  @relation(fields: [startUserId], references: [id])
  workflow_templates workflow_templates     @relation(fields: [templateId], references: [id])
  workflow_logs      workflow_logs[]
  workflow_tasks     workflow_tasks[]

  @@index([businessType, businessId])
  @@index([projectId, status])
  @@index([startUserId, status])
}

model workflow_logs {
  id                 Int                @id @default(autoincrement())
  instanceId         Int
  taskId             Int?
  userId             Int
  action             String
  details            Json?
  createdAt          DateTime           @default(now())
  workflow_instances workflow_instances @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  users              users              @relation(fields: [userId], references: [id])

  @@index([instanceId, createdAt])
}

model workflow_tasks {
  id                   Int                    @id @default(autoincrement())
  instanceId           Int
  nodeId               String
  nodeName             String
  taskType             WorkflowTaskType
  assignmentType       String
  assignmentValue      String
  candidateUsers       Int[]
  actualAssignee       Int?
  approvalType         String                 @default("single")
  requiredCount        Int?
  status               WorkflowTaskStatus     @default(PENDING)
  startTime            DateTime               @default(now())
  endTime              DateTime?
  deadline             DateTime?
  result               String?
  comments             String?
  attachments          String[]
  conditionExpression  String?
  priority             Priority               @default(MEDIUM)
  task_approvals       task_approvals[]
  workflow_delegations workflow_delegations[]
  users                users?                 @relation(fields: [actualAssignee], references: [id])
  workflow_instances   workflow_instances     @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([actualAssignee, status])
  @@index([instanceId, status])
}

model workflow_templates {
  id                 Int                  @id @default(autoincrement())
  name               String
  description        String?
  category           String
  version            Int                  @default(1)
  isActive           Boolean              @default(true)
  isDefault          Boolean              @default(false)
  nodeData           Json
  edgeData           Json
  canvasConfig       Json?
  startNodeId        String
  endNodeIds         String[]
  variables          Json?
  createdById        Int
  departmentId       Int?
  roleIds            Int[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime @updatedAt
  workflow_instances workflow_instances[]
  users              users                @relation(fields: [createdById], references: [id])
  departments        departments?         @relation(fields: [departmentId], references: [id])

  @@unique([category, name, version])
}

