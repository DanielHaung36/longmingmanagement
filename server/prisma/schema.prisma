  tasks_tasks_assignedUserIdTousers                           tasks[]                     @relation("tasks_assignedUserIdTousers")
  tasks_tasks_authorUserIdTousers                             tasks[]                     @relation("tasks_authorUserIdTousers")
  tasks_tasks_deleteRequestedByTousers                        tasks[]                     @relation("tasks_deleteRequestedByTousers")
  quotations_quotations_createdByTousers                      quotations[]                @relation("quotations_createdByTousers")
